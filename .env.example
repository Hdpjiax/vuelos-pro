NEXT_PUBLIC_SUPABASE_URL=tu_url_de_supabase
NEXT_PUBLIC_SUPABASE_ANON_KEY=tu_anon_key_de_supabase
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# RapidAPI Sky Scrapper
# Guarda tu llave real en Vercel/local, no la subas al repositorio.
RAPIDAPI_KEY=tu_rapidapi_key
SKY_SCRAPPER_RAPIDAPI_HOST=sky-scrapper.p.rapidapi.com
SKY_SCRAPPER_AIRPORTS_ENDPOINT=/api/v1/flights/searchAirport
SKY_SCRAPPER_FLIGHTS_ENDPOINT=/api/v2/flights/searchFlights
SKY_SCRAPPER_COUNTRY_CODE=MX
SKY_SCRAPPER_MARKET=es-MX
FLIGHT_SEARCH_DEFAULT_CURRENCY=MXN

# Opcional: deja true para probar sin consumir RapidAPI.
FLIGHT_SEARCH_USE_MOCK=false
